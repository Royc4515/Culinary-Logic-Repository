# ─── Telegram ───────────────────────────────────────────────────────────────
# Obtain from @BotFather on Telegram
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

# ─── Groq LLM ────────────────────────────────────────────────────────────────
# Obtain from https://console.groq.com
GROQ_API_KEY="your_groq_api_key"

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Enable the "Geocoding API" in Google Cloud Console
# Restrict the key to the Geocoding API only for safety
MAPS_API_KEY="your_google_maps_api_key"

# ─── Supabase ────────────────────────────────────────────────────────────────
# From: Project Settings → API
SUPABASE_URL="https://your-project-ref.supabase.co"
# Use the SERVICE ROLE key (not anon key) to bypass Row Level Security
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
