# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Backend Secrets ---
# Provided by BotFather in Telegram
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

# Bot's @username (without the @) — used to build the deep-link
# https://t.me/<TELEGRAM_BOT_USERNAME>?start=link_<token> in /api/link/start.
TELEGRAM_BOT_USERNAME="your_bot_username"

# Groq API for LLM parsing (default provider; also powers voice + photo)
GROQ_API_KEY="your_groq_api_key"

# Text-extraction provider: groq (default) | gemini | anthropic.
# Voice transcription and photo vision always use Groq.
# LLM_PROVIDER="groq"
# GEMINI_API_KEY="your_gemini_api_key"      # required if LLM_PROVIDER=gemini
# GEMINI_MODEL="gemini-2.5-flash"
# ANTHROPIC_API_KEY="your_anthropic_api_key"  # required if LLM_PROVIDER=anthropic
# ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# Restricted to Google Maps Geocoding API
MAPS_API_KEY="your_google_maps_api_key"

# Supabase database connection and service role key for bypassing RLS
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# Comma-separated origins allowed to call the backend via CORS (e.g. your frontend
# URL). Leave unset/blank for permissive "*" in local development. Any non-empty
# value enables restricted mode, so keep this commented out locally and set it only
# in your deployed environment, e.g.:
#   ALLOWED_ORIGINS="https://your-app-url.example.com"
ALLOWED_ORIGINS=""

# Frontend configuration
# VITE_APP_URL: public URL of the frontend; used as the OAuth redirect when running
# behind a tunnel/proxy in local dev.
VITE_APP_URL="https://your-app-url.example.com"
# VITE_BACKEND_URL: base URL of the Flask backend the frontend calls.
VITE_BACKEND_URL="https://your-backend-url.example.com"

# Frontend Supabase keys
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"
